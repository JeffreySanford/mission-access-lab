# Storybook's webpack5 builder and @angular-devkit/build-angular (pulled in
# transitively via @nx/angular's peer dependency) both resolve webpack@5 with
# different peer contexts under pnpm's default strict isolation, producing two
# separate content-addressed instances of the "same" version — this breaks
# webpack's internal `instanceof Compilation` checks across plugin boundaries.
# Hoisting avoids the duplicate-instance problem entirely.
node-linker=hoisted
