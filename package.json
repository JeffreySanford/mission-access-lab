{
  "name": "mission-access-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Nx polyglot training lab for Angular, Spring Boot, OpenFGA, PostgreSQL, testing, observability, and CI/CD.",
  "license": "MIT",
  "scripts": {
    "start": "nx run-many -t serve --projects=access-portal,authorization-wrapper --parallel=2",
    "start:web": "nx serve access-portal",
    "start:api": "nx serve authorization-wrapper",
    "build": "nx run-many -t build --all",
    "test": "nx run-many -t test --all",
    "lint": "nx run-many -t lint --all",
    "graph": "nx graph",
    "infra:up": "nx run infra:up",
    "infra:down": "nx run infra:down",
    "infra:reset": "nx run infra:reset",
    "fga:bootstrap": "node tools/openfga/bootstrap.mjs",
    "fga:test": "docker run --rm -v \"${PWD}/authorization:/authorization\" openfga/cli:v0.7.15 model test --tests /authorization/model-tests.yaml",
    "verify": "node tools/verify-workspace.mjs"
  },
  "dependencies": {
    "@angular/animations": "22.0.7",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@angular/platform-browser-dynamic": "22.0.7",
    "@angular/router": "22.0.7",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@nx/angular": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/workspace": "23.1.0",
    "@types/jasmine": "5.1.9",
    "@typescript-eslint/eslint-plugin": "8.38.0",
    "@typescript-eslint/parser": "8.38.0",
    "eslint": "9.31.0",
    "jasmine-core": "5.9.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "nx": "23.1.0",
    "sass": "1.89.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
