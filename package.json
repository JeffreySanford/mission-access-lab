{
  "name": "mission-access-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Nx polyglot training lab for Angular, Spring Boot, OpenFGA, PostgreSQL, testing, observability, and CI/CD.",
  "license": "MIT",
  "scripts": {
    "start:all": "nx run-many -t serve --projects=access-portal,authorization-wrapper --parallel=2",
    "start:web": "nx serve access-portal",
    "start:api": "nx serve authorization-wrapper",
    "build": "nx run-many -t build --all",
    "test": "nx run-many -t test --all",
    "lint": "nx run-many -t lint,eslint:lint --all && pnpm run lint:yaml && pnpm run lint:compose",
    "lint:yaml": "eslint infra .github --no-warn-ignored",
    "lint:compose": "docker compose -f infra/compose.yaml config --quiet",
    "graph": "nx graph",
    "infra:up": "nx run infra:up",
    "infra:down": "nx run infra:down",
    "infra:reset": "nx run infra:reset",
    "fga:bootstrap": "node tools/openfga/bootstrap.mjs",
    "fga:test": "node tools/openfga/test-model.mjs",
    "verify": "node tools/verify-workspace.mjs",
    "verify:e2e-contract": "node tools/verify-e2e-contract.mjs",
    "verify:release": "node tools/verify-release.mjs",
    "e2e:resilience": "nx run access-portal:e2e-resilience"
  },
  "dependencies": {
    "@angular/animations": "22.0.7",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@angular/platform-browser-dynamic": "22.0.7",
    "@angular/router": "22.0.7",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@nx/angular": "23.1.0",
    "@nx/devkit": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/eslint-plugin": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/playwright": "23.1.0",
    "@nx/storybook": "23.1.0",
    "@nx/web": "23.1.0",
    "@nx/workspace": "23.1.0",
    "@playwright/test": "^1.37.0",
    "@storybook/angular": "^10.5.0",
    "@swc/helpers": "~0.5.18",
    "@types/jasmine": "5.1.9",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "angular-eslint": "22.1.0",
    "eslint": "9.39.5",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-yml": "3.6.0",
    "jasmine-core": "5.9.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "nx": "23.1.0",
    "prettier": "~3.6.2",
    "sass": "1.89.2",
    "storybook": "^10.5.0",
    "ts-node": "10.9.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "yaml-eslint-parser": "2.1.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "webpack": "5.106.2",
      "axios": "1.18.1",
      "brace-expansion": "5.0.7",
      "minimatch@3.1.5>brace-expansion": "1.1.16",
      "esbuild": "0.28.1",
      "@hono/node-server": "2.0.11",
      "webpack-dev-server": "5.2.6",
      "uuid": "11.1.1"
    }
  }
}
