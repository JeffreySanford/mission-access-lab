{
  "name": "authorization-wrapper",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/authorization-wrapper/src/main/java",
  "tags": ["scope:authorization", "type:app", "language:java"],
  "targets": {
    "serve": { "executor": "nx:run-commands", "continuous": true, "options": { "cwd": "apps/authorization-wrapper", "command": "./gradlew bootRun" } },
    "build": { "executor": "nx:run-commands", "outputs": ["{projectRoot}/build"], "options": { "cwd": "apps/authorization-wrapper", "command": "./gradlew build" } },
    "test": { "executor": "nx:run-commands", "outputs": ["{projectRoot}/build/test-results", "{projectRoot}/build/reports/tests"], "options": { "cwd": "apps/authorization-wrapper", "command": "./gradlew test" } },
    "clean": { "executor": "nx:run-commands", "options": { "cwd": "apps/authorization-wrapper", "command": "./gradlew clean" } }
  }
}
